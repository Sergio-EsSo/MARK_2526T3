<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

<xs:element name="operaciones">
    <xs:complexType>
        <xs:sequence>
            <xs:element ref="operacion" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
</xs:element>

<xs:element name="operacion">
    <xs:complexType>
        <xs:sequence>
            <xs:choice maxOccurs="unbounded" minOccurs="1">
                <xs:element ref="venta" maxOccurs="unbounded" minOccurs="0"/>
                <xs:element ref="compra" maxOccurs="unbounded" minOccurs="0"/>
            </xs:choice>
        </xs:sequence>
    </xs:complexType>
</xs:element>

<xs:element name="venta">
    <xs:complexType>
        <xs:sequence>
            <xs:element name="titulo" type="xs:string" maxOccurs="unbounded"/>
            <xs:element name="cantidad" type="xs:integer" maxOccurs="unbounded"/>
            <xs:element name="entregado" type="xs:boolean" minOccurs="0"/>
            <xs:element ref="importe"/>
        </xs:sequence>
    </xs:complexType>
</xs:element>

<xs:element name="compra">
    <xs:complexType>
        <xs:sequence>
            <xs:element name="titulo" type="xs:string" maxOccurs="unbounded"/>
            <xs:element name="proveedor" type="xs:string"/>
            <xs:element ref="fecha_compra"/>
        </xs:sequence>
    </xs:complexType>
</xs:element>

<xs:element name="importe">
    <xs:complexType>
        <xs:simpleContent>
            <xs:extension base="xs:string">
                <xs:attribute name="moneda" type="xs:string" use="required"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
</xs:element>

<xs:element name="fecha_compra">
    <xs:complexType>
        <xs:sequence>
            <xs:element name="dia" type="xs:integer"/>
            <xs:element name="mes" type="xs:integer"/>
            <xs:element name="año" type="xs:integer"/>
        </xs:sequence>
    </xs:complexType>
</xs:element>

</xs:schema>